{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tank Battle",
  "version": "0.2.0",
  "identifier": "dev.agents.tank-battle",
  "build": {
    "beforeDevCommand": "vp dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "vp build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Tank Battle",
        "width": 1180,
        "height": 780,
        "minWidth": 860,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Game",
    "shortDescription": "Agents-generated tank battle game.",
    "longDescription": "A Tank Battle game generated by OpenAI Codex agents with Vue, Vite+, Web, and Tauri desktop targets."
  }
}
